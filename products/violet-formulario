  <script>
    (function(){const CONTACT={whatsapp:'5511923734039'}; const form=document.getElementById('qualForm'); const errorBox=document.getElementById('errorBox'); const resultBox=document.getElementById('resultBox'); const fallbackLink=document.getElementById('fallbackLink'); function waUrl(phone,text){return 'https://wa.me/'+String(phone).replace(/\D/g,'')+'?text='+encodeURIComponent(text||'');} function val(id){const el=document.getElementById(id); return el ? el.value.trim() : '';} form.addEventListener('submit', function(e){e.preventDefault(); const fields={empresa:val('empresa'),nome:val('nome'),segmento:val('segmento'),volume:val('volume'),equipe:val('equipe'),objetivo:val('objetivo'),travamento:val('travamento')}; const isValid=Object.values(fields).every(Boolean); if(!isValid){errorBox.style.display='block'; resultBox.style.display='none'; return;} errorBox.style.display='none'; const message='Olá! Vim pela página da Violet e já fiz a qualificação rápida.\n\n*Nome:* '+fields.nome+'\n*Empresa:* '+fields.empresa+'\n*Segmento:* '+fields.segmento+'\n*Volume médio de mensagens/dia:* '+fields.volume+'\n*Hoje alguém responde o WhatsApp?* '+fields.equipe+'\n*Objetivo principal:* '+fields.objetivo+'\n*Onde o WhatsApp mais trava hoje:* '+fields.travamento+'\n\nQuero entender se a Violet faz sentido para o meu caso.'; const url=waUrl(CONTACT.whatsapp,message); fallbackLink.href=url; resultBox.style.display='block'; if(typeof gtag==='function'){gtag('event','generate_lead',{event_category:'qualification',event_label:'violet_whatsapp_qualified'}); gtag('event','conversion',{'send_to':'AW-17945612305/r57ECOnT-4McEJGgke1C'});} window.open(url,'_blank','noopener,noreferrer');});})();
